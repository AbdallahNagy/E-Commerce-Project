    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "1", "description": "Page number (default: 1)" },
                { "key": "limit", "value": "10", "description": "Items per page (default: 10, max: 100)" },
                { "key": "category", "value": "", "description": "Filter by category ID", "disabled": true },
                { "key": "minPrice", "value": "", "description": "Minimum price filter", "disabled": true },
                { "key": "maxPrice", "value": "", "description": "Maximum price filter", "disabled": true },
                { "key": "search", "value": "", "description": "Full-text search", "disabled": true },
                { "key": "sort", "value": "", "description": "Sort order: price_asc | price_desc | rating (default: newest)", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Product",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", ":id"],
              "variable": [{ "key": "id", "value": "<productId>" }]
            }
          }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
