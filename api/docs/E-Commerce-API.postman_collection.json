    {
      "name": "Cart",
      "description": "All endpoints require authentication.",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart"]
            }
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"<productId>\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart"]
            }
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cart/:itemId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart", ":itemId"],
              "variable": [{ "key": "itemId", "value": "<cartItemId>", "description": "The _id of the cart item (from Get Cart response)" }]
            },
            "description": "Set quantity to 0 to remove the item."
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cart/:itemId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart", ":itemId"],
              "variable": [{ "key": "itemId", "value": "<cartItemId>" }]
            }
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart"]
            },
            "description": "Removes the entire cart document."
          }
        }
      ]
    },
    {
      "name": "Orders",
      "description": "All endpoints require authentication.",
      "item": [
        {
          "name": "Create Order (from Cart)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"New York\",\n    \"state\": \"NY\",\n    \"zip\": \"10001\",\n    \"country\": \"US\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "description": "Creates an order from the current cart, decrements stock, and clears the cart."
          }
        },
        {
          "name": "Get Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "description": "Returns own orders for regular users. Admins receive all orders."
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", ":id"],
              "variable": [{ "key": "id", "value": "<orderId>" }]
            }
          }
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderStatus\": \"shipped\",\n  \"paymentStatus\": \"paid\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", ":id", "status"],
              "variable": [{ "key": "id", "value": "<orderId>" }]
            },
            "description": "orderStatus values: processing | shipped | delivered | cancelled. paymentStatus values: pending | paid | failed | refunded."
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/:id/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", ":id", "cancel"],
              "variable": [{ "key": "id", "value": "<orderId>" }]
            },
            "description": "Cancels an order (only allowed when orderStatus is 'processing'). Restores product stock."
          }
        }
      ]
    },
